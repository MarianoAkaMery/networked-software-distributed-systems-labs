    {
        "id": "parse_command",
        "type": "function",
        "z": "b156758da18eca8a",
        "name": "Parse Command",
        "func": "let text = msg.originalMessage.text.trim();\nlet parts = text.split(/\\s+/);\nlet cmd = parts[0].toUpperCase();\n\nmsg.userId = msg.originalMessage.from.id;\n\nif (cmd === \"QUERY\" || cmd === \"TRACK\") {\n    msg.location = {\n        city: parts[1],\n        country: parts[2]\n    };\n}\n\nswitch (cmd) {\n    case \"QUERY\":\n        msg.command = \"QUERY\";\n        return [msg, null, null];\n\n    case \"TRACK\":\n        msg.command = \"TRACK\";\n        return [null, msg, null];\n\n    case \"REPORT\":\n        msg.command = \"REPORT\";\n        return [null, null, msg];\n\n    default:\n        msg.payload = \"Unknown command\";\n        return [msg, null, null];\n}\n",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 210,
        "y": 380,
        "wires": [
            [
                "build_query_url"
            ],
            [
                "track_location"
            ],
            [
                "report_user"
            ]
        ]
    },
    {
        "id": "build_query_url",
        "type": "function",
        "z": "b156758da18eca8a",
        "name": "Build Weather URL (QUERY)",
        "func": "let text = msg.originalMessage.text.trim();\nlet parts = text.split(/\\s+/);   // [\"QUERY\",\"Milan\",\"IT\"]\n\nmsg.command = parts[0].toUpperCase();\nmsg.location = {\n    city: parts[1],\n    country: parts[2]\n};\n\nreturn msg;  \n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 260,
        "wires": [
            [
                "bc5986b601f7610b",
                "14bbeb72651cf3e0"
            ]
        ]
    },
    {
        "id": "track_location",
        "type": "function",
        "z": "b156758da18eca8a",
        "name": "Track Location",
        "func": "let tracks = flow.get('tracks') || {};\nlet userTracks = tracks[msg.userId] || [];\n\nuserTracks.push({\n    city: msg.location.city,\n    country: msg.location.country\n});\n\ntracks[msg.userId] = userTracks;\nflow.set('tracks', tracks);\n\n// You can either let the chatbot-message build the reply from msg.location\n// or keep this payload, both are fine.\nmsg.payload = `Tracking temperature for ${msg.location.city}!`;\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 380,
        "wires": [
            [
                "a1fc7b7ac8aacdf1",
                "18bc17bcfa8bd1a9"
            ]
        ]
    },
    {
        "id": "report_user",
        "type": "function",
        "z": "b156758da18eca8a",
        "name": "Prepare REPORT list",
        "func": "let tracks = flow.get('tracks') || {};\nlet userTracks = tracks[msg.userId] || [];\n\n// Split node will iterate over this array\nmsg.payload = userTracks;\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
