    {
        "id": "collect_report",
        "type": "function",
        "z": "b156758da18eca8a",
        "name": "Collect REPORT Data",
        "func": "// In node-red-node-openweathermap, temperature in °C is msg.payload.tempc\nlet temp = msg.payload.tempc;\n\n// Location object set earlier: msg.location = { city, country }\nlet city = msg.location.city;\n\n// Build one line of output\nlet entry = `The temperature in ${city} is ${temp}°C!`;\n\n// Collect all lines (Join node will merge them)\nmsg.payload = entry;\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
